  questName: "B\xED m\u1EADt r\u1EEBng s\xE2u"
  description: "\"Tr\u01B0\u1EDFng l\xE0ng nghe th\u1EA5y ti\u1EBFng \u0111\u1ED9ng
    l\u1EA1. Gi\xFAp tr\u01B0\u1EDFng l\xE0ng \u0111i \u0111i\u1EC1u tra\""
  type: 2
  prerequisiteQuest: {fileID: 0}
  nextQuest: {fileID: 11400000, guid: 57d814927eaeb0a4bb8c8e73e0415eba, type: 2}
  autoAcceptNextQuest: 1
  targetName: "Orc b\xED \u1EA9n"
  requiredAmount: 1
  requiredItem: {fileID: 0}
  goldReward: 200
  itemReward: {fileID: 0}
  startDialogue:
  - "\"Ch\xE0o c\u1EADu ! Xin h\u1ECFi c\u1EADu c\xF3 th\u1EDDi gian cho ta kh\xF4ng
    ?\""
  - "Trong r\u1EEBng c\xF3 hi\u1EC7n t\u01B0\u1EE3ng l\u1EA1, kh\xE1m ph\xE1 gi\xFAp
    ta xem c\xF3 g\xEC x\u1EA3y ra \u1EDF \u0111\xF3 \u0111\u01B0\u1EE3c kh\xF4ng?\""
  progressDialogue:
  - "\"\u1EDE trong r\u1EEBng x\u1EA3y ra chy\u1EC7n g\xEC v\u1EADy ?\""
  - "\"C\u1EADu \u0111\xE3 t\xECm ra ch\u01B0a ?\""
  completeDialogue:
  - "\"Ra l\xE0 v\u1EADy\""
  - "\"C\u1EA3m \u01A1n th\xF4ng tin c\u1EE7a c\u1EADu\""
  - "\"Ta c\xF3 th\xEAm th\u1EED th\xE1ch kh\xE1c cho c\u1EADu \u0111\xE2y ?                                                                                                                                                                                                                                                                                                                                   
    \""
  targetDialogue:
  - "\"C\xF3 1 b\xED m\u1EADt m\xE0 n\u01A1i y\xEAn b\xECnh n\xE0y \u0111ang c\u1EA5t
    gi\u1EA5u....\""
  - "\"N\u01A1i m\xE0 sinh m\u1EA1ng c\u1EE7a k\u1EBB n\xE0y ch\u1EC9 l\xE0 th\u1EE9c
    \u0103n \u0111\u1EC3 hi\u1EBFn t\u1EBF cho k\u1EBB kh\xE1c...\""
  - "\"...v\xEC th\u1EBF n\xEAn c\u1EADu h\xE3y c\u1EA9n th\u1EADn\""
  endStoryText: "\"Sau khi k\u1EC3 cho \xF4ng l\xE3o nghe v\u1EC1 c\xE2u truy\u1EC7n
    trong r\u1EEBng\""
