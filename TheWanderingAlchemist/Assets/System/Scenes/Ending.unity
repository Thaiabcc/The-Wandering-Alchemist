      m_Calls: []
  m_text: "The guardian has fallen.\r\n\r\nFor the first time in ages, the ancient
    sigils shine once more.\r\n\r\nThe Decay begins to fade.\r\nNot all at once \u2014
    but enough for the world to breathe again.\r\n\r\nFlowers bloom where ash once
    covered the earth.\r\nThe old alchemical flame burns once more.\r\n\r\nYet beyond
    the horizon,\r\nmany secrets still remain.\r\n\r\nYour journey is not over.\r\n\r\n<size=80%><i>The
    flame is rekindled\u2026 and the road goes on.</i></size>\r\n"
  m_isRightToLeft: 0
